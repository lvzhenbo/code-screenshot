{
  "name": "lzb-code-screenshot",
  "version": "0.1.2",
  "publisher": "lvzhenbo",
  "license": "MIT",
  "displayName": "代码截图",
  "description": "一个用于在 VSCode 中快速截图代码的扩展，支持多种自定义设置和高质量图片输出。",
  "repository": {
    "type": "git",
    "url": "https://github.com/lvzhenbo/code-screenshot.git"
  },
  "bugs": {
    "url": "https://github.com/lvzhenbo/code-screenshot/issues"
  },
  "homepage": "https://github.com/lvzhenbo/code-screenshot#readme",
  "icon": "public/favicon.png",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "vscode": "^1.108.0"
  },
  "main": "dist/extension/index.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "code-screenshot.openWebview",
        "title": "打开代码截图"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "code-screenshot.openWebview",
          "group": "z_commands"
        }
      ]
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix",
    "format": "prettier --write --experimental-cli src/",
    "prepare": "husky",
    "release": "release-it"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@release-it/conventional-changelog": "^10.0.6",
    "@tailwindcss/vite": "^4.2.2",
    "@tomjs/vite-plugin-vscode": "^7.1.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.110.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vscode-elements/elements": "^2.5.1",
    "@vscode/vsce": "^3.7.1",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.1",
    "@vueuse/core": "^14.2.1",
    "@zumer/snapdom": "^2.6.0",
    "es-toolkit": "^1.45.1",
    "eslint": "^10.1.0",
    "eslint-plugin-vue": "^10.8.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.1",
    "reactive-vscode": "1.0.0-beta.2",
    "release-it": "^19.2.4",
    "shiki": "^4.0.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^8.0.2",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vue": "^3.5.30",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.6"
  },
  "packageManager": "pnpm@10.33.0"
}
